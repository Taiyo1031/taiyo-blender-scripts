# Python / Blender cache
__pycache__/
*.py[cod]

# macOS
.DS_Store

# Local editor and tool caches
.cache/
.vscode/
.idea/

# Build scratch output
/build/
/dist/
/*.zip

# Blender backup/autosave files
*.backup
*.blend1
*.blend2
